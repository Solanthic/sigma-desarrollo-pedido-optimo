#!/bin/sh
set -eu
repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
foundry_api_url=${FOUNDRY_API_URL:-https://salimentos-ia.palantirfoundry.com}
if [ -z "${FOUNDRY_TOKEN:-}" ]; then
  env_file="$repo_dir/.env"
  if [ -f "$env_file" ]; then
    # shellcheck disable=SC1090
    set -a
    . "$env_file"
    set +a
  fi
fi
if [ -z "${FOUNDRY_TOKEN:-}" ]; then
  echo "Missing Foundry token. Set FOUNDRY_TOKEN in $repo_dir/.env or export it in your shell." >&2
  exit 1
fi
exec "$repo_dir/node_modules/.bin/palantir-mcp" --foundry-api-url "$foundry_api_url" "$@"
